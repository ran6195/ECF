{
    "name": "edysma/ecf-backend",
    "description": "ECF — Edysma Centralized Forms · backend API (Slim 4 + Eloquent)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "illuminate/database": "^10.0",
        "vlucas/phpdotenv": "^5.6",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Ecf\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ecf\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php",
        "fresh": [
            "@migrate",
            "@seed"
        ],
        "test": "phpunit --colors=always"
    },
    "config": {
        "sort-packages": true
    }
}
