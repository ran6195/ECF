# === Configurazione COLLAUDO (edysma.net/testECF) ===
# Copia questo file in backend/.env.production e compila i valori del DB di collaudo,
# poi lancia deploy/build.sh. Questo file finirà come app/.env nel pacchetto.

# --- Database di collaudo (compila con i dati del pannello hosting) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=__NOME_DB_COLLAUDO__
DB_USERNAME=__UTENTE_DB__
DB_PASSWORD=__PASSWORD_DB__

# --- App ---
APP_ENV=production
APP_DEBUG=false
# URL pubblica base (senza slash finale)
APP_URL=https://edysma.net/testECF
# Sottocartella in cui gira l'app
APP_BASE_PATH=testECF

# --- Auth / JWT (genera un secret lungo e casuale!) ---
JWT_SECRET=__CAMBIA_CON_SECRET_CASUALE_LUNGO__
JWT_TTL=28800

# --- Admin iniziale (per il seed/import SQL) ---
ADMIN_EMAIL=admin@edysma.net
ADMIN_PASSWORD=__SCEGLI_PASSWORD_ADMIN__
