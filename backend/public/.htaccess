# Rewrite di tutte le richieste verso il front controller Slim,
# eccetto i file realmente esistenti (es. embed.js).
# Inoltra l'header Authorization a PHP (spesso rimosso da Apache/CGI/FPM).
<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Copia l'header Authorization nell'ambiente (fallback per il JWT).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Se il file richiesto esiste, servilo direttamente.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Altrimenti instrada verso index.php.
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Cache lunga per il loader statico (versionato via ?v= nello snippet).
<IfModule mod_headers.c>
    <FilesMatch "embed\.js$">
        Header set Cache-Control "public, max-age=86400"
    </FilesMatch>
</IfModule>
