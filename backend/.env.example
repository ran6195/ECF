# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ECFDatabase
DB_USERNAME=root
DB_PASSWORD=

# --- App ---
APP_ENV=local
APP_DEBUG=true
# URL pubblica base dell'API (usata per snippet/embed; senza slash finale)
APP_URL=http://localhost:8080

# --- Auth / JWT ---
# Cambia questo valore in produzione con una stringa lunga e casuale.
JWT_SECRET=change-me-to-a-long-random-secret
# Durata token in secondi (default 8 ore).
JWT_TTL=28800

# --- Admin di seed ---
ADMIN_EMAIL=admin@edysma.test
ADMIN_PASSWORD=password
